{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    ["@semantic-release/changelog", { "changelogFile": "CHANGELOG.md" }],
    ["@semantic-release/exec", {
      "prepareCmd": "jq '.KPlugin.Version = \"${nextRelease.version}\"' metadata.json > metadata.json.tmp && mv metadata.json.tmp metadata.json && npm run build && zip -r \"krect-v${nextRelease.version}.kwinscript\" metadata.json contents/"
    }],
    ["@semantic-release/git", {
      "assets": ["package.json", "package-lock.json", "CHANGELOG.md", "metadata.json"],
      "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
    }],
    ["@semantic-release/github", {
      "assets": [{ "path": "krect-v*.kwinscript", "label": "krect-v${nextRelease.version}.kwinscript" }]
    }]
  ]
}
